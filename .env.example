# Server-side only — read by api/generate.js via process.env.GEMINI_API_KEY.
# Do NOT prefix with VITE_ / NEXT_PUBLIC_ — that would expose the key to the browser bundle.
# Get a key: https://aistudio.google.com/app/apikey
# Set this in Vercel Project Settings → Environment Variables for production.
GEMINI_API_KEY=
